# Base URL for the application under test
BASE_URL=https://qa.example.com

# API Base URL (if different from BASE_URL)
API_BASE_URL=https://api.qa.example.com

# Environment name
ENV=qa

# Test credentials (use secrets in CI/CD)
TEST_USERNAME=admin
TEST_PASSWORD=admin

# Browser settings
BROWSER=chromium
HEADLESS=true

# Timeout settings (milliseconds)
TIMEOUT=30000
ACTION_TIMEOUT=5000

# Retry settings
RETRIES=2

# Screenshot & video
SCREENSHOT=only-on-failure
VIDEO=retain-on-failure
